{
  "default_project": "template",
  "projects": {
    "template": {
      "display_name": "Seed Project",
      "merge_policy": {
        "critical": "manual_only",
        "moderate": "one_human",
        "risky": "two_humans",
        "safe": "auto_if_green"
      },
      "risk_tier": "moderate",
      "scorecards": [
        "docs-hygiene",
        "runtime-boot",
        "automation-harness-health"
      ],
      "source_path": ".",
      "validation": [
        "deno task validate",
        "deno task score --vector docs-hygiene",
        "deno task score --vector runtime-boot",
        "deno task score --vector automation-harness-health"
      ],
      "workflow": {
        "path": "AGENTS.md"
      }
    }
  }
}
